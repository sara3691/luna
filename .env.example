VITE_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GROQ_API_KEY_2=
VITE_GROQ_API_KEY_3=

# 🔍 SERP API Key (Live Scholarship & Course Search)
# Get from: https://serpapi.com → Dashboard
VITE_SERP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

